{
  "name": "openpi",
  "private": true,
  "version": "0.1.10",
  "type": "module",
  "description": "OpenPi desktop workbench for the Pi coding agent.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --config electron-builder.json",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:electron": "npm run build && node scripts/smoke-electron.mjs",
    "test:e2e": "npm run build && playwright test",
    "release:version": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "release:prerelease": "node scripts/release.mjs prerelease",
    "brew:update": "node scripts/update-brew.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@ff-labs/fff-node": "^0.7.2",
    "@kobalte/core": "^0.13.11",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@pierre/diffs": "^1.1.21",
    "@shikijs/transformers": "^3.9.2",
    "@solid-primitives/event-listener": "^2.4.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.3",
    "electron-window-state": "^5.0.3",
    "fuzzysort": "^3.1.0",
    "lucide-solid": "^1.14.0",
    "marked": "^15.0.12",
    "marked-shiki": "^1.2.1",
    "material-icon-theme": "^5.34.0",
    "morphdom": "^2.7.4",
    "motion": "^12.38.0",
    "nerdfonts-web": "^1.0.1",
    "remeda": "^2.34.0",
    "shiki": "^3.9.2",
    "simple-git": "^3.36.0",
    "solid-js": "^1.9.12",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.3.0",
    "virtua": "^0.49.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "autoprefixer": "^10.4.21",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.1.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^3.1.3"
  },
  "author": "OpenPi contributors",
  "license": "MIT"
}
