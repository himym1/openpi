{
  "name": "openpi",
  "private": true,
  "version": "0.1.16",
  "type": "module",
  "description": "OpenPi desktop workbench for the Pi coding agent.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --config electron-builder.json",
    "prepare": "git config core.hooksPath .githooks",
    "precommit": "bash scripts/harness-lint.sh --quiet && npm run lint",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:electron": "npm run build && node scripts/smoke-electron.mjs",
    "test:e2e": "npm run build && playwright test",
    "release:version": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "release:prerelease": "node scripts/release.mjs prerelease",
    "brew:update": "node scripts/update-brew.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@ff-labs/fff-node": "^0.7.2",
    "@kobalte/core": "^0.13.11",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@pierre/diffs": "^1.1.21",
    "@replit/codemirror-vim": "^6.3.0",
    "@shikijs/transformers": "^3.9.2",
    "@solid-primitives/event-listener": "^2.4.5",
    "@uiw/codemirror-theme-atomone": "^4.25.9",
    "@uiw/codemirror-theme-aura": "^4.25.9",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/codemirror-theme-nord": "^4.25.9",
    "@uiw/codemirror-theme-tokyo-night": "^4.25.9",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/codemirror-theme-xcode": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.1",
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "fuzzysort": "^3.1.0",
    "lucide-solid": "^1.14.0",
    "marked": "^15.0.12",
    "marked-shiki": "^1.2.1",
    "material-icon-theme": "^5.34.0",
    "morphdom": "^2.7.4",
    "motion": "^12.38.0",
    "nerdfonts-web": "^1.0.1",
    "remeda": "^2.34.0",
    "shiki": "^3.9.2",
    "simple-git": "^3.36.0",
    "solid-js": "^1.9.12",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.3.0",
    "virtua": "^0.49.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "autoprefixer": "^10.4.21",
    "electron": "^41.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^3.1.3"
  },
  "author": "OpenPi contributors",
  "license": "MIT"
}
